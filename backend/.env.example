# Eduvy-AI Backend — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.

# ── Database ─────────────────────────────────────────────────
# OPTION A — Individual vars (recommended for new setups)
# Use these when your password contains special characters
# like @ # ! % + & — no encoding needed, just paste as-is.
DB_HOST=localhost
DB_PORT=5432
DB_USER=eduvyai_user
DB_PASS=your_password_here
DB_NAME=eduvyai

# OPTION B — Single connection URL (comment out OPTION A if using this)
# If your password has special chars (@, #, !, %) they MUST be
# percent-encoded manually: @ → %40  # → %23  ! → %21  % → %25
# The backend auto-encodes them for you when DB_HOST is NOT set.
#DATABASE_URL=postgresql://eduvyai_user:your_password_here@localhost:5432/eduvyai

# ── JWT Auth ─────────────────────────────────────────────────
# REQUIRED: generate a strong random secret before deploying.
#   python -c "import secrets; print(secrets.token_hex(64))"
# ⚠ This secret also encrypts AI API keys stored in the database.
#   Changing it after keys are saved will invalidate all stored keys
#   and you will need to re-enter them in the Admin Panel.
JWT_SECRET=CHANGE_ME_use_a_long_random_string_at_least_64_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=30

# ── Environment ───────────────────────────────────────────────
# Set to "production" to disable /docs, /redoc, /openapi.json
ENV=development

# ── AI Provider Keys ─────────────────────────────────────────
# Keys are managed securely through the Admin Panel → AI Models tab.
# Log in at /admin/login and add up to 5 round-robin keys per
# provider (Groq, Gemini, Anthropic, OpenAI) directly from the UI.
# Keys are stored encrypted in the database — no .env entries needed.

# ── Database Connection Pool ──────────────────────────────────
# Min/max connections in the psycopg2 pool (default: 2 / 20)
DB_POOL_MIN=2
DB_POOL_MAX=20

# ── AI Response Cache ─────────────────────────────────────────
# Max cached entries and TTL in seconds (default: 2000 / 3600)
AI_CACHE_SIZE=2000
AI_CACHE_TTL=3600

# ── Razorpay Payments ────────────────────────────────────────
# Get keys from https://dashboard.razorpay.com/app/keys
# Use rzp_test_* keys for development, rzp_live_* for production.
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add your production domain here when deploying.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
