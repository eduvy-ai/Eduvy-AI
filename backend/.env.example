# Eduvy-AI Backend — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/eduvyai

# ── JWT Auth ─────────────────────────────────────────────────
# REQUIRED: generate a strong random secret before deploying.
#   python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=CHANGE_ME_use_a_long_random_string_at_least_64_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=30

# ── Environment ───────────────────────────────────────────────
# Set to "production" to disable /docs, /redoc, /openapi.json
ENV=development

# ── AI Provider Keys (server-side only) ──────────────────────
# Free/Basic plans → Groq (required)
# Pro/Premium plans → any of the below (optional)

# Groq — https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI GPT — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add your production domain here when deploying.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
