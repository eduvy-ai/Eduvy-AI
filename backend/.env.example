# Eduvy-AI Backend — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/eduvyai

# ── JWT Auth ─────────────────────────────────────────────────
# REQUIRED: generate a strong random secret before deploying.
#   python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=CHANGE_ME_use_a_long_random_string_at_least_64_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=30

# ── Environment ───────────────────────────────────────────────
# Set to "production" to disable /docs, /redoc, /openapi.json
ENV=development

# ── AI Provider Keys (server-side only) ──────────────────────
# Each provider supports up to 5 keys (_2 … _5 suffix).
# All keys for a provider are round-robined automatically —
# multiply your quota by simply adding more accounts/keys.

# ── Groq (free tier — required for free/basic plans) ─────────
# https://console.groq.com/keys  |  5 accounts = 5× RPM
GROQ_API_KEY=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=

# ── Google Gemini (pro/premium plans, or paid scale) ─────────
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=

# ── Anthropic Claude (optional future paid LLM) ───────────────
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY_2=
ANTHROPIC_API_KEY_3=
ANTHROPIC_API_KEY_4=
ANTHROPIC_API_KEY_5=

# ── OpenAI GPT (optional future paid LLM) ────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_API_KEY_2=
OPENAI_API_KEY_3=
OPENAI_API_KEY_4=
OPENAI_API_KEY_5=

# ── Database Connection Pool ──────────────────────────────────
# Min/max connections in the psycopg2 pool (default: 2 / 20)
DB_POOL_MIN=2
DB_POOL_MAX=20

# ── AI Response Cache ─────────────────────────────────────────
# Max cached entries and TTL in seconds (default: 2000 / 3600)
AI_CACHE_SIZE=2000
AI_CACHE_TTL=3600

# ── Razorpay Payments ────────────────────────────────────────
# Get keys from https://dashboard.razorpay.com/app/keys
# Use rzp_test_* keys for development, rzp_live_* for production.
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add your production domain here when deploying.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
